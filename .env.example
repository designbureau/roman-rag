# Supabase project (server-side, used by CLI for REST upserts and Edge Functions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI for embeddings (text-embedding-3-small, 1536 dim)
OPENAI_API_KEY=

# Anthropic for generation (a temperature-accepting Claude, e.g. Sonnet) — set as Edge Function secret
ANTHROPIC_API_KEY=

# ElevenLabs for text-to-speech / transcription (used by the `speak` and
# `transcribe` Edge Functions). Set as a Supabase Edge Function secret, not a
# local .env value. Optional per-persona voice ID overrides — same scope:
#   ELEVENLABS_VOICE_CLASSICIST, ELEVENLABS_VOICE_CICERO,
#   ELEVENLABS_VOICE_TIRO, ELEVENLABS_VOICE_ATTICUS, ELEVENLABS_VOICE_CAESAR.
ELEVENLABS_API_KEY=

# Frontend (web/) — exposed in browser. Set in web/.env.local for local dev.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: override the Edge Function URLs (default to <SUPABASE_URL>/functions/v1/<name>)
VITE_CHAT_FN_URL=
VITE_SEARCH_FN_URL=
VITE_SPEAK_FN_URL=
VITE_TRANSCRIBE_FN_URL=
